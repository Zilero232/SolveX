{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2022",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"]
    },
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "messages.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "entities/**/*.ts",
    "entities/**/*.tsx",
    "features/**/*.ts",
    "features/**/*.tsx",
    "views/**/*.ts",
    "views/**/*.tsx",
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "widgets/**/*.ts",
    "widgets/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
