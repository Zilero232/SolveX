// Prisma is used for migrations only. Runtime queries go through supabase-js.
// Reason: Supabase RLS works on the JWT-authenticated client; Prisma Client would bypass it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  isPrivate Boolean  @default(false) @map("is_private")
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "rooms_created_at_idx")
  @@map("rooms")
}
