# =============================================================================
# Client public (Next) — NEXT_PUBLIC_* exposed to client bundle
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# =============================================================================
# Server-only (Next API routes) — never exposed to client bundle
# =============================================================================
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud

# =============================================================================
# Prisma (migrations only — runtime queries go through supabase-js)
# Get value from Supabase Dashboard → Project Settings → Database → Connection string → "Direct connection"
# =============================================================================
DIRECT_URL="postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
