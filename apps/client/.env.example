# Chatovo web client — environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/client/.env.example apps/client/.env
#
# NEXT_PUBLIC_* values are baked into the build at `next build` time and are
# visible in the browser bundle — never put secrets here.
#
# The SAME file name `.env` is used for local dev, the production web build,
# and the Tauri desktop build. Only the VALUES differ. `.env` is git-ignored.

# API base URL.
#   - local dev:           http://localhost:4000
#   - production website:  /api   (same origin as the site, served by Caddy)
#   - Tauri desktop build: https://chatovo.ru/api   (absolute — the desktop
#                          app has no same-origin website to use a relative path)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase — publishable (anon) key only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# LiveKit signalling URL.
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
