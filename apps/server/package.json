{
  "name": "@chatovo/server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "predev": "node ./scripts/kill-port.mjs",
    "dev": "bun --hot --cwd ../.. --env-file apps/server/.env apps/server/src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "db:push": "prisma db push && prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:reset": "prisma migrate reset",
    "db:format": "prisma format",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:setup-storage": "bun --env-file .env scripts/setup-storage.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@chatovo/schemas": "workspace:*",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@supabase/supabase-js": "^2.106.2",
    "hono": "^4.12.23",
    "livekit-server-sdk": "^2.15.4",
    "mime-types": "^3.0.2",
    "pg": "^8.21.0",
    "remeda": "^2.37.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mime-types": "^3.0.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "~6.0.3"
  }
}
