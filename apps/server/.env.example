# Chatovo API server — environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/server/.env.example apps/server/.env
#
# The SAME file name `.env` is used everywhere:
#   - locally:  read by `bun dev` (see package.json)
#   - on VPS:   loaded into the Docker container (see docker-compose.yml)
# Only the VALUES differ between dev and prod. `.env` is git-ignored;
# this `.env.example` is the only env file committed to the repo.

# `development` locally, `production` on the VPS.
NODE_ENV=development
PORT=4000

# Allowed web client origin(s), comma-separated.
# Production: the API lives on a separate subdomain (api.chatovo.ru) from the
# website (chatovo.ru), so the browser does send CORS preflight requests.
# Put the website origin here. Tauri origins (tauri://localhost) are always
# allowed automatically — no need to list them.
# Local dev value below; on the VPS .env use: CORS_ORIGINS=https://chatovo.ru
CORS_ORIGINS=http://localhost:3000

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# --- LiveKit ---
# Two deployment options — pick one and use matching values everywhere:
#   a) LiveKit Cloud:  LIVEKIT_URL=wss://<project>.livekit.cloud
#   b) Self-hosted:    LIVEKIT_URL=wss://livekit.chatovo.ru
#
# The API key and secret MUST match what is written in livekit.yaml on the VPS
# (for self-hosted) or what LiveKit Cloud shows in its dashboard. The browser
# never sees the secret — the server signs short-lived JWTs with it.
#
# Self-hosted setup: see infra/livekit/README.md and docs/deploy.md.
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://livekit.chatovo.ru

# --- Database (Prisma) ---
# Pooler URL for runtime queries (port 6543).
DATABASE_URL="postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct URL for migrations (port 5432). Not required at runtime — schema is
# managed manually with `bun db:push` from a developer machine.
DIRECT_URL="postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Optional: comma-separated admin emails.
ADMIN_EMAILS=
