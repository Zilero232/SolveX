# Chatovo API server — environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/server/.env.example apps/server/.env
#
# The SAME file name `.env` is used everywhere:
#   - locally:  read by `bun dev` (see package.json)
#   - on VPS:   loaded into the Docker container (see docker-compose.yml)
# Only the VALUES differ between dev and prod. `.env` is git-ignored;
# this `.env.example` is the only env file committed to the repo.

# `development` locally, `production` on the VPS.
NODE_ENV=development
PORT=4000

# Allowed web client origin(s), comma-separated.
# Production: the API lives on a separate subdomain (api.chatovo.ru) from the
# website (chatovo.ru), so the browser does send CORS preflight requests.
# Put the website origin here. Tauri origins (tauri://localhost) are always
# allowed automatically — no need to list them.
#
# Values per environment:
#   - VPS:               CORS_ORIGINS=https://chatovo.ru
#   - local, direct:     CORS_ORIGINS=http://localhost:3000
#   - local, via Caddy:  CORS_ORIGINS=https://chatovo.localhost
#     (docker-compose.dev.yml — mirrors the prod cross-origin + HTTPS layer)
CORS_ORIGINS=http://localhost:3000

# --- Auth (better-auth) ---
# Secret used to sign/encrypt tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Public base URL of THIS API server (where /auth/* is mounted).
#   - local dev:  http://localhost:4000
#   - production: https://api.chatovo.ru
BETTER_AUTH_URL=http://localhost:4000

# --- Google OAuth ---
# Create an OAuth client in Google Cloud Console → Credentials.
# Authorized redirect URI: <BETTER_AUTH_URL>/auth/callback/google
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# --- File uploads (local disk, served under /uploads) ---
# Directory where avatars + chat attachments are written. In Docker this is a
# mounted volume (see docker-compose.yml).

UPLOADS_DIR=./uploads
# Public origin files are served from (used to build absolute URLs in the DB).
#   - local dev:  http://localhost:4000
#   - production: https://api.chatovo.ru
PUBLIC_FILES_URL=http://localhost:4000

# --- LiveKit ---
# Options — pick one and use matching values everywhere:
#   a) LiveKit Cloud:        LIVEKIT_URL=wss://<project>.livekit.cloud
#   b) Self-hosted VPS:      LIVEKIT_URL=wss://livekit.chatovo.ru
#   c) Local dev SFU:        LIVEKIT_URL=ws://localhost:7880
#   d) Local dev via Caddy:  LIVEKIT_URL=ws://localhost:7880
#      (server still talks to the SFU directly; only the browser goes
#      through Caddy at ws://livekit.chatovo.localhost — see the client .env)
#
# The API key and secret MUST match the LiveKit side: the LiveKit Cloud
# dashboard (a), livekit.yaml on the VPS (b), or livekit.dev.yaml in the repo
# root (c). The browser never sees the secret — the server signs JWTs with it.
#
# Webhooks (live presence panel) only reach the API if LiveKit can POST to it.
# Cloud/VPS LiveKit cannot reach your localhost — for that use the local dev
# SFU (c): see infra/livekit/README.md → "Local development".
#
# Local dev (c) values: LIVEKIT_API_KEY=devkey, LIVEKIT_URL=ws://localhost:7880,
# LIVEKIT_API_SECRET=devsecret_devsecret_devsecret_32
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://livekit.chatovo.ru

# --- Database (self-hosted Postgres) ---
# POSTGRES_* are read by the postgres container in docker-compose.yml.
POSTGRES_USER=chatovo
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=chatovo

#
# Connection string used by Prisma + better-auth at runtime.
#   - in Docker:  host is the compose service name `postgres`
#   - local dev:  host is `localhost` and the port is published
# DATABASE_URL and DIRECT_URL are the same for a self-hosted single instance.
DATABASE_URL="postgresql://chatovo:replace-with-a-strong-password@postgres:5432/chatovo"
DIRECT_URL="postgresql://chatovo:replace-with-a-strong-password@postgres:5432/chatovo"
