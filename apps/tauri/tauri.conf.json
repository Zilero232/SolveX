{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solvex",
  "version": "0.1.0",
  "identifier": "com.react.solvex",
  "build": {
    "beforeDevCommand": "bun --filter @solvex/client dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun --filter @solvex/client build",
    "frontendDist": "../client/out"
  },
  "app": {
    "windows": [
      {
        "title": "Solvex",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
