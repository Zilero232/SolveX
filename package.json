{
  "name": "solvex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun --filter @solvex/client dev",
    "build": "bun --filter @solvex/client build",
    "start": "bun --filter @solvex/client start",
    "tauri": "bun --filter @solvex/tauri tauri",
    "tauri:dev": "bun --filter @solvex/tauri dev",
    "tauri:build": "bun --filter @solvex/tauri build",
    "lint": "biome check ./apps",
    "lint:fix": "biome check --write ./apps",
    "format": "biome format --write ./apps"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0"
  }
}
