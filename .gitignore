# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Deps
node_modules
*.local

# TypeScript incremental build info (can appear in any package)
*.tsbuildinfo

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Secrets — kept at root so they are caught in every package.
# The only env file committed is the template `.env.example`.
.env
.env.local
.env.*.local
!.env.example

# Tauri updater minisign keys
*.key
*.key.pub

# Package-specific build output is ignored by each package's own .gitignore:
#   apps/client/.gitignore   — .next/, out/, dist/
#   apps/server/.gitignore   — generated/, dist/
#   apps/tauri/.gitignore    — target/, gen/
